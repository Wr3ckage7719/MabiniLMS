# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:8080
# Comma-separated origins are supported (recommended to include both root + www)
# Example: https://mabinilms.vercel.app,https://www.mabinilms.vercel.app
CORS_ORIGIN=https://your-app.vercel.app

# Notes:
# - CLIENT_URL is the canonical frontend URL variable used by server code.
# - FRONTEND_URL is accepted as a fallback alias for compatibility only.

# Google OAuth (obtain from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Email Configuration
# Provider options: 'mock' (development), 'smtp', 'gmail'
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@mabinilms.edu.ph
EMAIL_FROM_NAME=MabiniLMS

# Production recommendation:
# - Set EMAIL_PROVIDER=smtp (or gmail)
# - Configure SMTP_* values below
# - Optionally manage these values at runtime via /api/admin/settings:
#   email_provider, email_from, email_from_name, smtp_host, smtp_port,
#   smtp_secure, smtp_user, smtp_pass

# SMTP Settings (for EMAIL_PROVIDER=smtp or gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Web Push Notifications (VAPID)
# Generate keys once with: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
# Must be a URL or mailto: contact for push providers
WEB_PUSH_SUBJECT=mailto:support@mabinilms.edu.ph
