{
  "name": "mabinilms",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" --names \"server,client\" --prefix-colors \"blue,green\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build:server && npm run build:client",
    "build:server": "npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "start:server": "npm run start --workspace=server",
    "preview:client": "npm run preview --workspace=client",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:migrate:status": "npm run db:migrate:status --workspace=server",
    "db:migrate:bundle": "npm run db:migrate:bundle --workspace=server",
    "db:migrate:up": "npm run db:migrate:up --workspace=server",
    "db:migrate:down": "npm run db:migrate:down --workspace=server",
    "db:migrate:create": "npm run db:migrate:create --workspace=server",
    "db:migrate:reset": "npm run db:migrate:reset --workspace=server",
    "supabase:query": "node scripts/supabase-linked-query.mjs",
    "supabase:ping": "node scripts/supabase-linked-query.mjs \"select 1 as ok;\"",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{js,ts,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "supabase": "^2.92.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "postgres": "^3.4.9"
  }
}
